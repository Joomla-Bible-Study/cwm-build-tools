{
    "extension": {
        "type": "package",
        "name": "pkg_cwmscripture",
        "displayName": "CWM Scripture"
    },
    "manifests": {
        "package": "build/pkg_cwmscripture.xml",
        "extensions": [
            { "type": "library", "path": "libraries/lib_cwmscripture/cwmscripture.xml" },
            { "type": "plugin",  "path": "scripturelinks.xml" },
            { "type": "plugin",  "path": "plg_task_cwmscripture/cwmscripture.xml" }
        ]
    },
    "build": {
        "command": "php build/build-package.php",
        "outputGlob": "build/dist/pkg_cwmscripture-*.zip"
    },
    "ars": {
        "endpoint": "https://www.christianwebministries.org",
        "categoryId": 3,
        "updateStreamId": 4,
        "environments": ["45", "46", "48", "49", "50"],
        "tokenItem": "CWM ARS API Token",
        "tokenVault": "CWM"
    },
    "github": {
        "owner": "Joomla-Bible-Study",
        "repo": "CWMScriptureLinks",
        "releaseBranch": "main"
    },
    "changelog": {
        "file": "build/cwmscripture-changelog.xml",
        "url":  "https://raw.githubusercontent.com/Joomla-Bible-Study/CWMScriptureLinks/main/build/cwmscripture-changelog.xml"
    },
    "announcement": {
        "command": "cwm-article",
        "bulletsDir": "build"
    }
}
