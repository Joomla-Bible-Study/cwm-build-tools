{
    "_comment": "Per-project config for cwm-build-tools. Replace placeholder values and remove this comment.",
    "extension": {
        "type": "package",
        "name": "pkg_yourextension"
    },
    "manifests": {
        "package": "build/pkg_yourextension.xml",
        "extensions": [
            { "type": "library", "path": "libraries/lib_yourextension/yourextension.xml" },
            { "type": "plugin",  "path": "yourextension.xml" }
        ]
    },
    "build": {
        "command": "php build/build-package.php",
        "outputGlob": "build/dist/pkg_yourextension-*.zip"
    },
    "ars": {
        "endpoint": "https://www.christianwebministries.org",
        "categoryId": 0,
        "updateStreamId": 0,
        "environments": ["45", "46", "48", "49", "50"],
        "tokenItem": "CWM ARS API Token",
        "tokenVault": "CWM",
        "itemDescription": "One-paragraph description shown on the ARS public download page."
    },
    "github": {
        "owner": "Joomla-Bible-Study",
        "repo": "YourRepo",
        "releaseBranch": "main",
        "developmentBranch": "development"
    },
    "versionsFile": "build/versions.json",
    "changelog": {
        "file": "build/yourextension-changelog.xml",
        "url":  "https://raw.githubusercontent.com/Joomla-Bible-Study/YourRepo/main/build/yourextension-changelog.xml"
    },
    "announcement": {
        "bulletsDir": "build",
        "command": "bash build/cwm-article.sh"
    },
    "dev": {
        "_comment": "Optional. Drives cwm-link / cwm-link-check / cwm-clean / cwm-verify.",
        "deriveLinks": true,
        "internalLinks": [
            { "source": "yourextension.xml",       "link": "admin/yourextension.xml" },
            { "source": "yourextension.script.php", "link": "admin/yourextension.script.php" }
        ],
        "links": [
            {
                "source": "language/admin/en-GB/en-GB.com_yourextension.ini",
                "target": "{joomlaPath}/administrator/language/en-GB/en-GB.com_yourextension.ini"
            }
        ]
    }
}
