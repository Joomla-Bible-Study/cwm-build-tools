{
    "name": "cwm/build-tools",
    "description": "Shared build, release, and CI tooling for CWM Joomla extensions",
    "type": "library",
    "license": "GPL-2.0-or-later",
    "keywords": ["joomla", "build", "release", "ars", "cwm"],
    "authors": [
        {
            "name": "CWM Team",
            "homepage": "https://www.christianwebministries.org"
        }
    ],
    "require": {
        "php": "^8.3",
        "ext-json": "*",
        "ext-simplexml": "*",
        "ext-zip": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "friendsofphp/php-cs-fixer": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "CWM\\BuildTools\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CWM\\BuildTools\\Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/cwm-release",
        "bin/cwm-bump",
        "bin/cwm-package",
        "bin/cwm-sync-configs",
        "bin/cwm-sync-languages",
        "bin/cwm-ars-publish",
        "bin/cwm-ars-list",
        "bin/cwm-ars-create-stream",
        "bin/cwm-changelog",
        "bin/cwm-init",
        "bin/cwm-setup",
        "bin/cwm-link",
        "bin/cwm-link-check",
        "bin/cwm-clean",
        "bin/cwm-verify",
        "bin/cwm-joomla-install",
        "bin/cwm-joomla-latest"
    ],
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    }
}
